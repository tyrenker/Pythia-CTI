# Pythia configuration — copy to .env and fill in
# Never commit .env

# --- API ---
PYTHIA_ENV=development
# Default 127.0.0.1 = localhost only. Set to 0.0.0.0 to expose on your LAN.
PYTHIA_HOST=127.0.0.1
PYTHIA_PORT=8000
PYTHIA_LOG_LEVEL=INFO

# --- Auth ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
PYTHIA_API_KEY=changeme-generate-a-strong-key

# --- Database ---
# Local dev (default): SQLite file
PYTHIA_DATABASE_URL=sqlite:///./pythia.db
# Production example:
# PYTHIA_DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/pythia

# --- Claude / Anthropic ---
ANTHROPIC_API_KEY=sk-ant-...
PYTHIA_CLAUDE_MODEL=claude-sonnet-4-6

# --- Ingestion ---
PYTHIA_SCRAPE_USER_AGENT=Pythia/0.1 (+https://github.com/tyrenker/Pythia-CTI)
PYTHIA_SCRAPE_RATE_LIMIT_PER_MIN=20
